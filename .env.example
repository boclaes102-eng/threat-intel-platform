# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/threat_intel
DB_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
ACCESS_TOKEN_EXPIRY=15m          # short-lived JWT
REFRESH_TOKEN_EXPIRY_DAYS=30     # long-lived refresh token stored in DB

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call this API
CORS_ORIGIN=http://localhost:3000

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
IOC_CACHE_TTL=3600
CVE_CACHE_TTL=21600

# ── External APIs (all optional — tools degrade gracefully without them) ──────
ABUSEIPDB_API_KEY=
VT_API_KEY=
NVD_API_KEY=
OTX_API_KEY=

# ── Email alerts (optional — skipped silently if SMTP_HOST is unset) ──────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@threat-intel.local

# ── Observability ─────────────────────────────────────────────────────────────
# Grafana admin password (docker-compose only)
GRAFANA_PASSWORD=admin
